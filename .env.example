# Frontend (Vite React) - client/.env
# Copy this file to client/.env and adjust values.
VITE_API_URL=http://localhost:4000


# Backend (Node/Express) - server/.env
# Copy this file to server/.env and adjust values.
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/coding-vieb
JWT_SECRET=replace-with-long-random-secret
CORS_ORIGIN=http://localhost:5173

